{
    "version": 2,
    "builds": [
        {
            "src": "toko_samudra/index.html",
            "use": "@vercel/static"
        },
        {
            "src": "toko_samudra/assets/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/toko_samudra/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/toko_samudra/index.html"
        }
    ]
}
